{
  "version": 2,
  "buildCommand": "npm run build",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/frontend/dist/assets/:path*"
    },
    {
      "source": "/favicon.svg",
      "destination": "/frontend/dist/favicon.svg"
    },
    {
      "source": "/((?!api|auth).*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
